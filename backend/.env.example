PORT=3000

# MongoDB Atlas (recommended): paste your mongodb+srv connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Local fallback (app forces DB name from MONGODB_DB_NAME below, not the path segment):
# MONGODB_URI=mongodb://127.0.0.1:27017/

# Must match the database in Compass (default `test` — alerts read from this DB, not `medifollow`)
MONGODB_DB_NAME=test

# Optional: if SRV DNS fails on your network, uncomment (uses Google + Cloudflare DNS for Node only)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

#PATIENT_ROLE_ID=

# Optional: Groq API key — doctor alert message suggestions + nurse medical file handwriting import (vision)
# https://console.groq.com — vision uses meta-llama/llama-4-scout-17b-16e-instruct (override with GROQ_VISION_MODEL)
GROQ_API_KEY=
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Verify active MongoDB database vs Compass: GET http://localhost:3000/database
# Collection counts: GET http://localhost:3000/alerts/data-summary

OPENAI_API_KEY=your_openai_api_key_here
